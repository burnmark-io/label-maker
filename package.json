{
  "name": "@burnmark-io/label-maker",
  "version": "0.1.0",
  "private": true,
  "description": "Design beautiful labels — Vue 3 web app for thermal label printing.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue,.js",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@burnmark-io/designer-core": "latest",
    "@burnmark-io/designer-vue": "latest",
    "@burnmark-io/sheet-templates": "latest",
    "@thermal-label/brother-ql-web": "latest",
    "@thermal-label/contracts": "latest",
    "@thermal-label/labelmanager-web": "latest",
    "@thermal-label/labelwriter-web": "latest",
    "@thermal-label/transport": "latest",
    "@vueuse/core": "^11.0.0",
    "idb": "^8.0.0",
    "konva": "^9.0.0",
    "pako": "^2.0.0",
    "pinia": "^2.0.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.13.0",
    "vue-konva": "^3.0.0",
    "vue-router": "^4.0.0",
    "xlsx": "latest"
  },
  "devDependencies": {
    "@mbtech-nl/eslint-config": "^1.0.1",
    "@mbtech-nl/prettier-config": "^1.0.0",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.0"
  },
  "prettier": "@mbtech-nl/prettier-config"
}
