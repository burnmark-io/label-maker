{
  "name": "@burnmark-io/label-maker",
  "version": "0.1.0",
  "private": true,
  "description": "Design beautiful labels — Vue 3 web app for thermal label printing.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .ts,.vue,.js",
    "format": "prettier --write \"src/**/*.{ts,vue,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@burnmark-io/designer-core": "link:../designer-core/packages/core",
    "@burnmark-io/designer-vue": "link:../designer-core/packages/vue",
    "@burnmark-io/sheet-templates": "link:../sheet-templates",
    "@mbtech-nl/bitmap": "link:../../mbtech/bitmap",
    "@thermal-label/brother-ql-core": "link:../../thermal-label/brother-ql/packages/core",
    "@thermal-label/brother-ql-web": "link:../../thermal-label/brother-ql/packages/web",
    "@thermal-label/contracts": "link:../../thermal-label/contracts",
    "@thermal-label/labelmanager-core": "link:../../thermal-label/labelmanager/packages/core",
    "@thermal-label/labelmanager-web": "link:../../thermal-label/labelmanager/packages/web",
    "@thermal-label/labelwriter-core": "link:../../thermal-label/labelwriter/packages/core",
    "@thermal-label/labelwriter-web": "link:../../thermal-label/labelwriter/packages/web",
    "@thermal-label/transport": "link:../../thermal-label/transport",
    "@vueuse/core": "^11.0.0",
    "idb": "^8.0.0",
    "jszip": "^3.10.1",
    "konva": "^9.0.0",
    "pako": "^2.0.0",
    "pinia": "^2.0.0",
    "vue": "^3.4.0",
    "vue-i18n": "^9.13.0",
    "vue-konva": "^3.0.0",
    "vue-router": "^4.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@mbtech-nl/eslint-config": "link:../../mbtech/configs/packages/eslint-config",
    "@mbtech-nl/prettier-config": "link:../../mbtech/configs/packages/prettier-config",
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.3",
    "@types/w3c-web-serial": "^1.0.8",
    "@types/w3c-web-usb": "^1.0.14",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.0",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.0",
    "prettier": "^3.0.0",
    "typescript": "~5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.0.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.0",
    "workbox-window": "^7.4.0"
  },
  "prettier": "@mbtech-nl/prettier-config"
}
